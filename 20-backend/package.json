    "helmet": "^7.1.0",
    "@hubspot/api-client": "^11.2.0",
    "openai": "^4.57.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "@prisma/client": "^5.18.0",
    "nodemailer": "^6.9.14",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20",
    "typescript": "^5",
    "tsx": "^4.19.0",
    "prisma": "^5.18.0",
    "eslint": "^8",
    "@typescript-eslint/parser": "^7.8.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0"
